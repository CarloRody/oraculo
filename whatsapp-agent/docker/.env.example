# Copie para ".env" (mesma pasta) e gere uma chave forte, ex: openssl rand -hex 32
# Essa MESMA chave também vai em config.yaml -> evolution_api.api_key (nome do
# bloco mantido como "evolution_api" no config.yaml por simplicidade, mesmo
# apontando pro conector WAHA)
WAHA_API_KEY=troque-por-uma-chave-forte
